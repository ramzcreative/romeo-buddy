{
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.js",
    "dev:default": "cross-env CUSTOM_THEME=default CUSTOM_SRC_PATH=themes/default/src CUSTOM_TEMPLATES_PATH=themes/default/templates vite --config vite.config.js",
    "dev:coastal": "cross-env CUSTOM_THEME=coastal CUSTOM_SRC_PATH=themes/coastal/src CUSTOM_TEMPLATES_PATH=themes/coastal/templates vite --config vite.config.js",
    "build": "npm run build:themes",
    "build:default": "cross-env CUSTOM_THEME=default CUSTOM_SRC_PATH=themes/default/src CUSTOM_TEMPLATES_PATH=themes/default/templates vite build --config vite.config.js",
    "build:coastal": "cross-env CUSTOM_THEME=coastal CUSTOM_SRC_PATH=themes/coastal/src CUSTOM_TEMPLATES_PATH=themes/coastal/templates vite build --config vite.config.js",
    "build:themes": "npm run build:default && npm run build:coastal && npm run svg-build && npm run favicon-build && npm run logo-build",
    "preview": "vite preview --config vite.config.js",
    "svg-build": "svgo -f themes/_base/src/icons -o web/dist/assets/icons -r --config svgo.config.js",
    "favicon-build": "node scripts/build-favicons.mjs",
    "logo-build": "node scripts/build-logos.mjs"
  },
  "dependencies": {
    "@fancyapps/ui": "^5.0.30",
    "lazysizes": "^5.3.2",
    "lenis": "^1.3.14",
    "motion": "^12.23.24",
    "motion-plus": "https://api.motion.dev/registry?package=motion-plus&version=1.5.4&token=61d5d6cb3f10f1f8752b0eb2f8d91b5a449c28d5f62ec0a2baffe8871ca6f7fb",
    "postcss-advanced-variables": "^4.0.0",
    "svgo": "^3.0.2",
    "swiper": "^14.0.5",
    "uuid": "^13.0.0",
    "vite": "^6.4.3",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-restart": "^2.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.13",
    "cross-env": "^7.0.3",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.5.6",
    "postcss-custom-media": "^9.1.2",
    "postcss-custom-selectors": "^7.1.2",
    "postcss-each": "^1.1.0",
    "postcss-hover-media-feature": "^1.0.2",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.1",
    "postcss-pxtorem": "^6.0.0",
    "postcss-simple-vars": "^7.0.1",
    "sharp": "^0.35.3",
    "terser": "^5.37.0",
    "vite-plugin-manifest-sri": "^0.2.0"
  },
  "browserslist": [
    "defaults"
  ]
}
