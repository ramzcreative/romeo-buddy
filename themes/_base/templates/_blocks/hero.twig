{#
# Template purpose: builder
# - prep data for each text block
# - pass data to each block as an 'include'
#}

{% set entry = entry ?? false %}

{% if entry %}

    {% set isLast = last ?? false %}
    {% set layout = entry['layoutHero'] ?? 'standard' %}
    {% set preloadImage = preloadImage ?? false %}

    {% include "_blocks/layouts/hero/#{layout}" with{entry: entry, isLast: isLast, preloadImage: preloadImage } %}
{% endif %}