{% if blocks %}

    {% set handleAdded = [] %}
    {% set parent = parent ?? 'builder' %}
    {% set previous = false %}
        
    {% for chunk in blocks %}
        {% if chunk.type == 'markup' %}
            {% include "_blocks/markup" with {"chunk": chunk, "index": loop.index, "last":loop.last, "parent": parent, "previous": previous } only %}
        {% else %}
            {% set handle = chunk.entry.type.handle %}
            {% set hasHandle = handle in handleAdded ? true : false %}
            {% set handleAdded = handleAdded|merge([handle]) %}

            {# get current index of similar blocks 
               - the number of times a similar block appears on the page
            {% if hasHandle %}        
                {% for key, value in handleAdded %}
                    {% if value == handle %}
                        {% set handleIndex = key %}
                    {% endif %}
                {% endfor %}
            {% endif %}
            #}
            
            {% include "_blocks/#{handle}" with {
                "entry": chunk.entry,
                "index": loop.index,
                "last":loop.last,
                "hasHandle" : hasHandle,
                "parent": parent,
                "previous": previous,
                "preloadImage": loop.first,
            } only %}

            {% set previous = handle %}
        {% endif %}
    {% endfor %}

{% endif %}