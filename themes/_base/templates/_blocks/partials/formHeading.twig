{% import '_utilities/format' as format %}



{% set headingSettings = entry['formHeading'].all() ?? false %}

{% if headingSettings %}

	{% for item in headingSettings %}

		{% set heading = item['heading'] ?? false %}
		{% set intro = item['intro'] ?? false %}

		<div class="form-header wrapper-text">

			<div class="form-header__int text-center">
				{% if layout == 'subscribe' %}
				<p class="stamp form-header__badge">✦ Join the Crew</p>
				{% endif %}

				{% if heading %}
				<h2 class="form-header__heading">{{ format.basic(heading) }}</h2>
				{% endif %}

				{% if intro %}
				{{intro|retconAttr('p', { class: 'faux-p-lg form-header__intro' })}}
				{% endif %}
			</div>

		</div>
	{% endfor %}

{% endif %}