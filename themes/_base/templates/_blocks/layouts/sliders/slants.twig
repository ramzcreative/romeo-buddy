
{#      
breakpoints='{
    "1024": {
        "slidesPerView": "auto",
        "spaceBetween": "50"
    }
}'    
#}

{% import '_utilities/format' as format %}
{% import '_utilities/transforms' as transform %}

{# need min of 6 slides #}
{% set total = items|length %}
{% set loopN = total < 6 ? 6 - total : 1 %}

<article class="slider-slants relative">

	{% include '_blocks/partials/heading' %}

	<div class="slider-slants__int">
            
        <swiper-container id="material" class="slider-slants__container swiper-material"
            init="false"
            navigation="true"
            speed="900"
            grab-cursor="true" 
            slides-per-view="1.5"
            effect="material"
            centered-slides="true"
            loop="true"
            loop-prevents-sliding="true"
            navigation="true"
        >

            {# loopN pads the item list with repeats for swiper's infinite loop —
               only the very first slide of the very first pass is actually
               visible on load, so that's the only one eligible to preload. #}
            {% for i in 1..loopN %}
                {% for item in items %}
                <swiper-slide class="slider-slants__slide swiper-slide">
                    <div class="slider-slants__wrapper swiper-material-wrapper">
                        <div class="slider-slants__content swiper-material-content">
                            {% include "_blocks/partials/sliders/slantPartial" with { item: item, index: loop.index, preloadImage:  } only %}

                            {% set preloadImage = loop.parent.loop.first and loop.first and (preloadImage ?? false) %}
                            {% set index = loop.index %}
                            
                            {% set heading = item['heading'] ?? false %}
                            {% set preheading = item['preheading'] ?? false %}
                            {% set intro = item['intro'] ?? false %}
                            {% set image = item['image'] ?? false %}

                            <div class="slider-slant__item relative">

                                {{format.getLinkAria(item.linkUrl)}}

                                {% if image %}
                                <div data-swiper-material-scale="1.25">
                                    {{ transform.getImage({
                                        'asset': image,
                                        'transform': 'card',
                                        'wrapperClasses': "slider-slant__image-wrapper",
                                        'classes': "slider-slant__image object-fit",
                                        'placeholder': true,
                                        'preload': preloadImage ?? false
                                    }) }}
                                </div>
                                {% endif %}

                                {#
                                <div class="card__info">
                                    <div class="card__info-int text-center">

                                        <div>
                                        {% if heading %}
                                        <p class="card__heading faux-p-lg">{{ format.basic(heading) }}</p>
                                        {% endif %}

                                        {{intro|retconAttr('p', { class: 'card__intro' })|retconAttr('a', { class: 'link' })}}
                                        </div>

                                        {% include '_blocks/buttons' with { entry: item, options: {classes:'btn card__btn link'}  } only %}
                                    </div>
                                </div>
                                #}
                            </div>
                        </div>
                    </div>
                </swiper-slide>
                {% endfor %}
            {% endfor %}

        </swiper-container>
		
	</div>
</article>