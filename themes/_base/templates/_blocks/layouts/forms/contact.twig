{% set uid = entry.uid ?? random() %}

<form class="form form--contact" method="POST" accept-charset="UTF-8" data-contact-form>
	{{ csrfInput() }}
	{{ actionInput('contact-form/send') }}
	<input type="hidden" name="message[formName]" value="contact">
	<input type="hidden" name="recaptchaToken" value="">
	{% include '_blocks/partials/honeypot' %}

	<div class="form__field">
		<label class="form__label" for="{{ uid }}-fromName">Name <span class="form__required">*</span></label>
		<input class="form__input" type="text" id="{{ uid }}-fromName" name="fromName" required>
	</div>

	<div class="form__field">
		<label class="form__label" for="{{ uid }}-fromEmail">Email <span class="form__required">*</span></label>
		<input class="form__input" type="email" id="{{ uid }}-fromEmail" name="fromEmail" required>
	</div>

	<div class="form__field">
		<label class="form__label" for="{{ uid }}-subject">Subject</label>
		<input class="form__input" type="text" id="{{ uid }}-subject" name="subject">
	</div>

	<div class="form__field">
		<label class="form__label" for="{{ uid }}-message">Message</label>
		<textarea class="form__textarea" id="{{ uid }}-message" name="message[body]"></textarea>
	</div>

	<div class="form__actions">
		<button type="submit" class="btn form__submit">Send Message</button>
		<noscript><p class="form__notice">JavaScript is required to submit this form.</p></noscript>
	</div>

	<div class="form__message" data-form-message hidden></div>
</form>
