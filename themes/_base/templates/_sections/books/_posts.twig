{% set featuredItem = featuredItem ?? false %}

{% paginate items as pageInfo, blogPosts %}

<div class="blog-posts section relative">

	{% include '_blocks/partials/heading' %}
	
    <div class="wrapper">
        {% if blogPosts or featuredItem %}
            {# place the featured item at the start of the array #}
            {% if featuredItem and pageInfo.currentPage == 1 %}
                {% set blogPosts = [featuredItem]|merge(blogPosts)%}
            {% endif %}

            <div class="blog-posts__items">
                {% for item in blogPosts %}
                    {% include '_sections/books/_card' with {isFeatured: featuredItem and pageInfo.currentPage == 1 and loop.index == 1 ? true : false } %}
                {% endfor %}
            </div>

            <div class="blog-posts__footer">
                <ul class="blog-posts__footer-links ignore">
                    {% for page, url in pageInfo.getDynamicRangeUrls(5) %}
                    <li><a href="{{ url }}" class="pagination__item {{ page == pageInfo.currentPage ? 'pagination__item--current'}}"
                            aria-label="Page {{ page }}">{{ page }}</a></li>
                    {% endfor %}
                </ul>
            </div>
        {% else %}
        <p class="blog-posts__none text-center">Sorry, no blog posts found</p>
        {% endif %}
    </div>
</div>