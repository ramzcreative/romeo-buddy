{% import '_utilities/nav' as nav %}

{% set email = general['email'] ?? footer['email'] ?? seoEmail() ?? false %}

{# footer navs #}
{% set links = navTree('footer') %}

<footer class="footer">

    {# footer form — same "Form" entry type/template as the page-builder
       block (footerForm field is restricted to it, maxEntries: 1). Not
       cache-wrapped like footer-nav below — this form embeds a CSRF
       token via csrfInput(), which must stay unique per request/session,
       so caching its markup would either break submissions or leak a
       stale token to every visitor.

       showFooterForm only exists on 'page'/'landingPage' entry types (see
       migrations/m260720_213719_addShowFooterFormField.php) — defaults to
       showing the form (matches the field's own "default: true") on any
       other entry type, or when there's no current entry at all, since
       `is same as(false)` only matches a real, explicit false. #}
    {% set showFooterForm = currentEntry and currentEntry['showFooterForm'] is same as(false) ? false : true %}
    {% set footerFormEntries = showFooterForm ? (footer['footerForm'].one() ?? false) : false %}
    {% if footerFormEntries %}
        {% include '_blocks/form' with { entry: footerFormEntries } only %}
    {% endif %}

    {# top footer #}
    <div class="footer-top section-padding section-padding--slim bg--black">
        <div class="footer-top__int wrapper">
            
            {# left/top column #}
            <div class="footer__column">

                {#
                
                {% set generalAddress = general.address.one() ?? null %}
                {% if generalAddress %}
                <p class="footer__address">{{ generalAddress|address }}</p>
                {% endif %}

                {% if general.phone %}
                <p class="footer__phone"><span class="bold">phone:</span> {{ general.phone }}</p>
                {% endif %}
                #}

                <a href="{{siteUrl}}" aria-label="return home" class="footer__logo-link">
                    {{logoSvg}}
                    <span class="footer__logo-text">Romeo &amp; Buddy</span>
                </a>
                <p>A children's book series about imagination, unplugging, and the biggest adventures a living room has ever seen.</p>

                <ul class="footer-social__items ignore">
                    {% include '_partials/social' %}
                </ul>

            </div>
            
            {# right/bottom column #}
            <div class="footer__column footer__column--grid">
                {# Pre-existing {% cache %} wrap, left as-is — worth knowing
                   it has the same caveat header.twig's own comment calls
                   out (active-state frozen to whichever page first
                   populated the cache), just lower-stakes here since footer
                   links rarely need per-page active highlighting. #}
                {% cache globally using key "footer-nav" %}
                    {% if links %}
                    <ul class="footer__nav ignore">
                        <li class="footer__nav-heading">Information</li>
                        {{ nav.standard(links)}}
                    </ul>
                    {% endif %}
                {% endcache %}

				{% if email %}
				<ul class="footer__nav ignore">
                        <li class="footer__nav-heading">Get In Touch</li>
						<li><a class="menu__link" href="mailto:{{email}}?subject=Lets Talk" >{{email}}</a></li>
				</ul>
				{% endif %}
            </div>
        </div>
    </div>

    {# bottom footer #}
    <div class="footer__bottom section-padding--slim my-0 bg--black">
        <div class="footer__bottom-wrapper wrapper">
            <p class="footer__copyright faux-p-xs">&copy; {{now|date('Y')}} {{footer.copyright}}</p>
        </div>
    </div>
</footer>