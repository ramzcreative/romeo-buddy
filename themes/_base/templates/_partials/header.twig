{% import '_utilities/nav' as nav %}

{% set mainLinks = craft.freenav.nodes('header').cache().all() ?? false %}

<header class="header" data-header-container>
    <div class="header__int">
    
        <a href="{{siteUrl}}" class="header-logo">
            {{logoSvg}}
            Romeo & Buddy
        </a>

        <button class="menu-btn menu-btn--nav" aria-label="Toggle main navigation" aria-expanded="false" aria-controls="main-nav" data-toggle-modal="main-nav" type="button">
            <div class="menu-btn__int">
                <div class="menu-btn__open">
                    <span class="menu__bar menu__bar--1"></span>
                    <span class="menu__bar menu__bar--2"></span>
                    <span class="menu__bar menu__bar--3"></span>
                </div>
                <div class="menu-btn__close">
                    <span class="menu__bar menu__bar--4"></span>
                    <span class="menu__bar menu__bar--5"></span>
                </div>
            </div>
        </button>

    </div>
</header>


<cta-modal id="main-nav" class="modal-nav" data-lenis-prevent>
    <div slot="modal">
        <a href="{{siteUrl}}" class="header-logo header-logo--menu">
            {{logoSvg}}
            Romeo & Buddy
        </a>
        <nav aria-label="Primary">
            <ul class="primary-nav ignore">
                {{ nav.menu(mainLinks)}}
            </ul>
        </nav>
    </div>
</cta-modal>