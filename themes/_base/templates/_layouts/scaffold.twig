{# asset paths #}
{% set mainCSSPath = craft.vite.entry("maincss.css") %}
{% set criticialPath = craft.vite.entry("critical.css") %}
{# activeThemeHandle is always set by modules/themepicker for real front-end
   requests — 'default' here only matters as a defensive fallback, same as
   config/general.php, config/vite.php, and config/colour-swatches.php all
   use. CUSTOM_THEME itself is no longer the active-theme source of truth
   (the CP theme picker is); it's still read directly by web/index.php for
   Craft's own bootstrap template path, which themepicker's runtime
   override doesn't reach on console/CP requests. #}
{% set themeDir =  'themes/' ~ (activeThemeHandle ?? 'default') %}
{% set currentEntry = entry is defined ? entry : null %}

<!doctype html>
<html lang="en-US" class="{{htmlClasses|default}} {{globalHeroOverlay|default(false) ? 'has--hero-overlay'}} {{globalHasHero|default(false) ? 'has--hero'}} {{globalShowForm|default(false) ? 'has--form'}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="apple-mobile-web-app-capable" content="yes">

    {# Plyr (the video-block player) creates its own YouTube/Vimeo iframe at
       runtime and strips any sandbox attribute we try to add to it — see
       https://github.com/sampotts/plyr/issues/2833 — so the embed domains
       are locked down here instead. Narrow: only restricts iframe/frame
       sources, doesn't touch scripts/styles/images. No other iframe exists
       anywhere in this theme. #}
    <meta http-equiv="Content-Security-Policy" content="frame-src 'self' https://www.youtube-nocookie.com https://player.vimeo.com;">

    {# ============================================
        SEO — title/meta/OG/Twitter + JSON-LD structured data.
        See modules/seo
    ============================================ #}
    {{ renderSeoTags(currentEntry) }}
    {{ renderStructuredData(currentEntry) }}

	<link rel="apple-touch-icon" sizes="180x180" href="/assets/themes/{{ activeThemeHandle }}/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/themes/{{ activeThemeHandle }}/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/themes/{{ activeThemeHandle }}/favicon-16x16.png">
    <link rel="icon" href="/assets/themes/{{ activeThemeHandle }}/favicon.ico" type="image/x-icon">
    {# favicon webmanifest <link rel="manifest" href="/site.webmanifest"> #}

    {# Dev only: craft.vite.script() always emits a <script>/<link> tag —
       there's no "inline" or "async" option — so critical/main CSS load
       through the dev server as JS modules here, the same as any other
       entry, which is what lets Vite's CSS HMR track them. Production
       takes a deliberately different path below (critical CSS inlined,
       main CSS loaded async) that this call can't produce, so it isn't
       used there. #}
    {% if craft.vite.devServerRunning() %}
    {{ craft.vite.script("#{themeDir}/src/js/critical.js", false) }}
    {{ craft.vite.script("#{themeDir}/src/js/maincss.js", false) }}
    {% endif %}

    {# ============================================
        PAGE STYLES
    ============================================ #}
	{% if not craft.vite.devServerRunning() %}
	<style>{{ craft.vite.inline(criticialPath) }}</style>

    <link href="{{mainCSSPath}}" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="{{mainCSSPath}}" rel="stylesheet"></noscript>
    {% endif %}


    {# ============================================
        MISC PAGE LINKS
    ============================================ #}
    {# Fonts are self-hosted (see themes/_base/src/css/base/fonts.pcss) —
       no Google Fonts request, so no visitor IP is sent to Google. #}
</head>

<body id="appcss" class="header-top">

    {# ============================================
        PAGE CONTENT
    ============================================ #}
    {% block body %}
    <div id="app">
        {# banner#}
        {% include '_partials/banner' %}

        {# nav/main header #}
        {% include '_partials/header' %}

        {# content header #}
        {% block header %}
        {% endblock %}

        {# main content #}
        <main class="main-content content-fade-in">
            {% block main %}
            {% endblock %}
        </main>
        
        {# footer content #}
        {% include '_partials/footer' %}
        
        {# edit button #}
        {% include "_partials/edit" %}
    </div>
    {% endblock %}
    {# ============================================
        END PAGE CONTENT
    ============================================ #}
    <div id="modal-holder" class="swiper-no-swiping"></div>

    {# cookie consent banner — see modules/stablestwigextensions and
       Components/cookieConsent.ts for the show/hide + storage logic #}
    {% include "_partials/cookieConsent" %}
    

    {# ============================================
        PAGE SCRIPTS
    ============================================ #}
    <script type="text/javascript">
        window.csrfTokenName = "{{ craft.app.config.general.csrfTokenName|e('js') }}";
        window.csrfTokenValue = "{{ craft.app.request.csrfToken|e('js') }}";
        window.environment = "{{ craft.app.config.env|e('js') }}";
        window.appUrl = "{{ getenv('APP_URL')|e('js') }}";
    </script>

    {{ craft.vite.script("#{themeDir}/src/js/main.js", true) }}   
</body>

</html>