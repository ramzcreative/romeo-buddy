{# Internal search results are exactly the kind of thin/duplicate content
   Google's own guidelines say shouldn't be indexed — with no backing entry
   there's no `seo.noindex` field to check, so scaffold.twig's
   renderSeoTags() call needs this explicit flag instead. See
   modules/seo/services/SeoResolver.php's getRobotsContent(). #}
{% set forceNoindex = true %}

{% extends '_layouts' %}

{% import '_utilities/format' as format %}
{% import '_utilities/transforms' as transform %}

{% set query = craft.app.request.getQueryParam('q') %}

{% set entries = query ? (craft.entries.search(query).all() ?? false) : false %}

{% block main %}
    <article class="search section relative">
        <div class="wrapper">

            <div class="search-header">
                <h1>Search</h1>

                <form class="search-form form-default" action="{{ url('search/') }}">
                    <input type="search" name="q" aria-label="Search" placeholder="Search">
                    
                    <button type="submit" class="btn">Search</button>
                </form>
            </div>

            {% if entries|length %}
            <div class="card card--search">
                <p class="search-query text-center">Entries related to "{{ query }}"</p>
                
                <div class="card__items">
                    {% for entry in entries %}

                    {% set heading = entry['heading'] ?? entry.title %}
                    {% set image = entry['image'] ?? false %}

                    <div class="card__item">
                        {{format.getLinkAria(entry)}}
                        
                        {{ transform.getImage({
                            'asset': image,
                            'transform': 'card',
                            'wrapperClasses': "card__image-wrapper",
                            'classes': "card__image object-fit",
                            'placeholder': true
                        }) }}

                        <div class="card__info">
                            <p class="card__heading">{{ format.basic(heading) }}</p>
                        </div>
                        
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% else %}
                {% if query %}
                <p>Your search for <span class="bold">“{{ query }}”</span> didn’t return any results.</p>
                {% endif %}
            {% endif %}
        </div>
    </article>

{% endblock %}
