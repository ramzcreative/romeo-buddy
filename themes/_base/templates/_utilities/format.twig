{# Both macros below allow a small set of inline formatting tags in
   otherwise-plain-text values (entry.title, PlainText fields like excerpt,
   etc. — none of which get HTMLPurifier's pass at save time the way
   CKEditor fields do). `striptags()` only filters tag *names*; it does not
   touch attributes on whatever tags survive, so `<a onmouseover="...">` or
   `<strong onclick="...">` passed straight through unchanged before — use
   Craft's `purify` filter (real HTMLPurifier) with an explicit allowlist
   instead, so a disallowed attribute or a `javascript:` href actually gets
   stripped, not just a disallowed tag name. #}
{% macro basic(str) %}
{% apply spaceless %}
    {% set str = str ?? '' %}

    {{ str|purify({
        'HTML.AllowedElements': ['small', 'sup', 'sub', 'strong', 'em', 'a', 'br'],
        'HTML.AllowedAttributes': ['a.href', 'a.target', 'a.rel'],
    }) }}
{% endapply %}
{% endmacro %}

{% macro simple(str) %}
{% apply spaceless %}
    {% set str = str ?? '' %}

    {{ str|purify({
        'HTML.AllowedElements': ['small', 'sup', 'sub', 'strong', 'em', 'br'],
        'HTML.AllowedAttributes': [],
    }) }}
{% endapply %}
{% endmacro %}

{% macro plain(str) %}
{% apply spaceless %}
    {% set str = str ?? '' %}

    {{ str|striptags()|raw }}
{% endapply %}
{% endmacro %}


{% macro getLink(link, classes) %}
{% apply spaceless %}
	{% if link ?? false %}
		{{ tag('a', {
			class: classes,
			href: link.value,
			target: link.target,
			rel: link.target == '_blank' ? 'noopener noreferrer' : null,
			text: link.label|default(craft.app.config.custom.linkDefault)
		}) }}
	{% endif %}
{% endapply %}
{% endmacro %}

{% macro getLinkAria(link, classes) %}
{% apply spaceless %}
	{% if link is instance of('craft\\elements\\Entry') %}
		{% set link = link.buttons.one() ?? false %}
		{% set link = link.linkUrl ?? false %}
	{% else %}
		{% set link = link ?? false %}
	{% endif %}

	{% if link %}
		{{ tag('a', {
			class: 'ada-link' ~ classes,
			href: link.value,
			target: link.target,
			rel: link.target == '_blank' ? 'noopener noreferrer' : null,
			'aria-hidden': 'true',
			'tabindex': '-1',
		}) }}
	{% endif %}
{% endapply %}
{% endmacro %}