{#
    Confirmation email — auto-reply sent back to submission.fromEmail after
    a form is submitted (see hybridinteractive/craft-contact-form-extensions'
    "Send confirmation email" setting; requires a `fromEmail` field on the
    form, which every layout in _blocks/layouts/forms/ already has).

    Plain inline-styled HTML, same reasoning as notification.twig — no
    linked/site build CSS, email clients don't render it reliably.
#}
{% set greetingName = submission.fromName ?? '' %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>We received your message</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f4f4; font-family:Arial, Helvetica, sans-serif;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f4; padding:24px 0;">
<tr>
<td align="center">
<table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:8px; overflow:hidden;">
<tr>
<td style="background-color:#ff6b4a; padding:20px 32px;">
<span style="color:#ffffff; font-size:18px; font-weight:bold;">Thanks for reaching out{{ greetingName ? ', ' ~ greetingName : '' }}!</span>
</td>
</tr>
<tr>
<td style="padding:32px; font-size:15px; color:#14213d; line-height:1.6;">
<p style="margin:0 0 16px;">We've received your message and will get back to you as soon as we can.</p>
<p style="margin:0;">In the meantime, feel free to browse <a href="{{ siteUrl }}" style="color:#00aeef;">{{ siteUrl }}</a>.</p>
</td>
</tr>
<tr>
<td style="padding:16px 32px; background-color:#f9f9f9; font-size:12px; color:#999999;">
This is an automated confirmation — no need to reply.
</td>
</tr>
</table>
</td>
</tr>
</table>
</body>
</html>
