{% set globalShowForm = true %}

{% extends '_layouts' %}

{% block main %}
<article class="section portal-login-block">
    <div class="wrapper">
        <form class="form form-reset" method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('users/send-password-reset-email') }}

            {% if errors is defined %}
            {{ ul(errors, {class: 'alert-error errors ignore'}) }}
            {% endif %}

            <div class="form__field">
                <label class="form__label" for="loginName">Username or email</label>
                {{ input('text', 'loginName', loginName ?? craft.app.user.rememberedUsername, {
                    id: 'loginName',
                    class: 'form__input',
                    autocomplete: 'username',
                }) }}
            </div>

            {% set success = craft.app.session.getFlash('notice') ?? false %}
            {% if success %}
            <p>{{ success }}</p>
            {% endif %}

            <div class="form__actions">
                <button type="submit" class="btn form__submit">Submit</button>
            </div>
        </form>
    </div>
</article>
{% endblock %}
