
:root {
    /* $colors (and this @each loop) removed 2026-07-22 -- every theme's
       hand-authored color1/color2/color3/black/gray/body/body-medium map
       is gone, migrated to the Color System roles and, for
       body/body-medium, to plain --body/--body-medium lines in each
       theme's own generated block (see themedesigner/CLAUDE.md and
       project_stables_color1_color2_to_design_system_migration.md --
       same migration already done for stables). */

    /* layouts */
    --content: 1200px;
    --wide: 1600px;
    --text: 65ch;

    --fluid-content-width: 87.5cqw;
    --fluid-content-max-width: var(--content);
    --fluid-content-clamped-width: min(var(--fluid-content-max-width), var(--fluid-content-width));
    --fluid-gutter-width: calc(50% - var(--fluid-content-clamped-width) / 2);

    --fluid-content-width-wide: 87.5cqw;
    --fluid-content-max-width-wide: var(--wide);;
    --fluid-content-clamped-width-wide: min(var(--fluid-content-max-width-wide), var(--fluid-content-width-wide));
    --fluid-gutter-width-wide: calc(50cqw - var(--fluid-content-clamped-width-wide) / 2);

    @media (--screen-lg){
        --fluid-content-width-wide: 90.278cqw;
    }

    /* spacers/font-sizes moved to generated/scale-generated.pcss (see
       critical.pcss's import order) — genuinely generated content,
       kept out of this otherwise hand-authored file. */

    /* radius */
    --radius-sm: 10px;
    --radius-md: 20px;
    --radius-lg: 32px;
    --radius-full: 50%;

    --radius: var(--radius-md);

    /* Typography — sizes (h1–h6, body, lists) */
    --font-primary: "ABeeZee", sans-serif;
    --font-heading: "Baloo Bhaina 2", sans-serif;

    /* font sizes moved to generated/scale-generated.pcss */

    /* font weights */
    --fw-light: 300;
    --fw-normal: 400;
    --fw-medium: 500;
    --fw-semibold: 600;
    --fw-bold: 700;
    --fw-heavy: 800;

    /* font line heights */
    --lh-xs: 1;
    --lh-sm: 1.15;
    --lh-base: 1.5;
    --lh-md: 1.6;
    --lh-lg: 1.7;
    --lh-xl: 1.8;

    /* letter spacing */
    --ls-xs: 0;
    --ls-sm: 0.5px;
    --ls-base: 1px;
    --ls-lg: 1.5px;
    --ls-xl: 2px;

    /* font colors */
    --font-color: var(--gray-dark);
    --font-color-dark: var(--gray-dark);
    --font-color-light: var(--gray-light);
    --font-color-dark-mode: #FFF;

    /* --on-color1/-color2/-color3/-black used to pair on-color text with
       the old color1/2/3/black roles' own bg--* swatches — those roles
       (and their bg--* classes) are gone, migrated to the Color System's
       own --on-{role} pairing (backgrounds-generated.pcss), so all 4 were
       dead weight and removed 2026-07-22.
       --on-body mirrors stables: aliased from the stable --gray-dark
       value, not --font-color itself, since --font-color gets
       contextually reassigned per surface below — a var() pointing at
       --font-color would just follow whichever override is active
       wherever it's read, defeating the point of a fixed reference. */
    --on-body: var(--gray-dark);

    /* error colors */
    --error: #f44336;

    /* links */
    --link-color-default: var(--primary);
    --link-border-color-default: transparent;
    --link-hover-color-default: var(--secondary);
    --link-hover-border-color-default: var(--secondary);

    --link-color: var(--link-color-default);
    --link-border-color: var(--link-border-color-default);
    --link-hover-color: var(--link-hover-color-default);
    --link-hover-border-color: var(--link-hover-border-color-default);


    /** header **/
    --header-height: 60px;

    @media (--screen-md){
        --header-height: 70px;
    }
    @media (--screen-lg){
        --header-height: 90px;
    }


    /* forms */
    --form-font-family: var(--font-primary);
    --form-fs: var(--fs-base);
    --form-font-color: var(--font-color);
    --form-fw: var(--fw-normal);

    --form-label-font-family: var(--form-font-family);
    --form-label-fs: var(--form-fs);
    --form-label-fw: var(--fw-bold);
    --form-label-color: var(--font-color);

    --form-input-font-family: var(--form-font-family);
    --form-input-fs: var(--form-fs);
    --form-input-fw: var(--form-fw);
    --form-input-color: var(--form-font-color);
    --form-input-bg: var(--body-medium);
    --form-input-border-color: transparent;
    --form-input-border-width: 0px;
    --form-input-border-radius: 6px;
    --form-input-padding: var(--spacer-1) var(--spacer-3) var(--spacer-1);

    --form-select-font-family: var(--form-input-font-family);
    --form-select-fs: var(--form-input-fs);
    --form-select-fw: var(--form-input-fw);
    --form-select-color: var(--form-input-color);
    --form-select-bg: var(--form-input-bg);

    --form-placeholder-color: var(--form-input-color);
    --form-placeholder-fw: var(--form-input-fw);

    --form-error-color: var(--alert-error, #f56565);
    --form-success-color: var(--alert-success, #00ae2a);

    --form-row-gap-y: var(--spacer-3);
    --form-row-gap-x: var(--spacer-3);

    @media (--screen-md){
        --form-row-gap-x: var(--spacer-5);
    }

    /* borders */
    --border-color: var(--gray, var(--primary));
    --border-width-lg: 8px;
    --border-width: 3px;
    --border-width-thin: 2px;

    /* focus rings */
    --ring-color: currentColor;
    --ring-size: 8px; /* must be larger that ring offset size */

    --ring-offset-size: 7px; /* offset size */
    --ring-offset-color: white;

    --ring-shadow: 0 0 0 var(--ring-offset-size) var(--ring-offset-color), 0 0 0 calc(1px + var(--ring-size)) var(--ring-color);

    /* shadows */
    --shadow-sm: 0px 0px 5px rgba(0,0,0,0.1);
    --shadow: 0 8px 18px rgba(99,99,99,0.1), 0 6px 6px rgba(99,99,99,0.1);
    --shadow-lg: 0 8px 18px rgba(0,0,0,0.12), 0 5px 5px rgba(0,0,0,0.1);

    /* transitions — var(--transition-base)/var(--transition-fast) were already the de facto standard, repeated
       as raw literals in 13+ component files with no shared token */
    --transition-fast: .25s;
    --transition-base: .5s;
    --transition-slow: .7s;
    --ease-default: ease-in-out;

    /* z-index — 9999/100000 were already the de facto "always on top"
       tiers, repeated as raw literals across header/cookieConsent/
       helpers/modal with no shared token */
    --z-behind: -1;
    --z-raised: 1;
    --z-sticky: 9999;
    --z-modal: 100000;

    --tst: #FFF;


    /* bg--*'s on-color pairing (font/link colors per surface) moved to
       generated/backgrounds-generated.pcss, alongside the fill rules —
       both halves are generator output. */

    /* text-only pairing, no background fill — for text sitting directly
       on an image (a slider caption, a photo hero, etc.) rather than a
       solid bg--* surface, where the .bg--* classes' background-color
       would either do nothing useful or need overriding back to
       transparent every time. Same white/dark-ink literals every bg--*
       class already resolves to at the extremes, just without the fill
       half of that pairing. */
    .text--light{
        --font-color: var(--font-color-dark-mode);
        --font-color-heading: var(--font-color-dark-mode);

        --link-color: var(--font-color-dark-mode);
        --link-border-color: var(--font-color-dark-mode);
        --link-hover-color: var(--font-color-dark-mode);
        --link-hover-border-color: var(--font-color-dark-mode);

        --form-label-color: var(--font-color-dark-mode);
    }
    .text--dark{
        --font-color: var(--font-color-dark);
        --font-color-heading: var(--font-color-dark);

        --link-color: var(--font-color-dark);
        --link-border-color: var(--font-color-dark);
        --link-hover-color: var(--font-color-dark);
        --link-hover-border-color: var(--font-color-dark);

        --form-label-color: var(--font-color-dark);
    }
}


/* bare .btn's token defaults moved to generated/buttons-generated.pcss,
   alongside .btn--primary/secondary/tertiary/neutral. */

.layout--grid {
    --grid-column--count: 4;
    --grid-gap--width: var(--space_grid-gap);
    --grid-gap--count: calc(var(--grid-column--count) - 1);
    --grid-gap--total: calc(var(--grid-gap--width) * var(--grid-gap--count));
    --grid-item--min-width: 250px;
    --grid-item--max-width: calc((100% - var(--grid-gap--total)) / var(--grid-column--count));
}

.dialog,
.popover{
    --popup-translate: 0 1em;
    --popup-wrapper-padding: var(--spacer-7);
    --popup-padding: var(--spacer-7);
    --popup-bg: #FFF;
    --popup-backdrop: hsl(0 0 0 / 80%);
    --popup-max-width: 700px;
}

/* offsets */
.columns{
    --col-offset-lg: 0;
    --col-offset-md: 0;
    --col-offset-sm: 0;

    @media (--screen-lg){
        --col-offset-lg: -300px;
        --col-offset-md: -200px;
        --col-offset-sm: -100px;
    }
}

/* footer offset */
.footer{
    --footer-offset: -70px;

    @media (--screen-md){
        --footer-offset: -90px;
    }
    @media (--screen-lg){
        --footer-offset: -112px;
    }
}