.footer{
    position: sticky;
    top: 100%;
}
.footer__logo-link{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;

    width: max-content;
    margin-bottom: 30px;

    svg{
        width: 50px;
    }
}
.footer__logo-text{
    font-family: var(--font-heading);
    color: #fff;
    font-size: 1.3rem;
}

.footer-top__int{
    display: flex;
    flex-direction: column;
    justify-content: space-between;

    @media (--screen-lg){
        flex-direction: row;
        gap: 60px;
    }
}

.footer__phone{
    margin-top: 10px;
}

.footer__bottom-wrapper{
    padding-top: 1.5rem;
    border-top: 1px solid #2a3557;
}

#appcss .footer__copyright{
    padding: 10px 0;
    color: white;
}

/*==========================================================
    NAV
==========================================================*/
.footer__nav{
    display: flex;
    flex-direction: column;
    gap: 10px;

    .menu__link{
        font-size: 16px;
        color: #FFF;

        transition: color .5s;
    
        @media (--screen-md){
            font-size: 18px;
        }

        @media (--screen-lg){
            white-space: nowrap;
        }

        &:hover,
        &:focus{
            color: var(--primary);
        }
    }
}
.footer__nav-heading{
    font-size: 22px;
    font-weight: 700;
}

.footer__column--grid{
	display: flex;
	gap: 45px;
}


/*==========================================================
    SOCIAL NAV
==========================================================*/
.footer-social__items{
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 30px;

    @media (--screen-md){
        gap: 28px;
        margin-top: 40px;
    }
}
.social__link{
    display: block;
    width: auto;
    height: 24px;
    color: white;

    transition: color .5s;

    @media (--screen-md){
        height: 32px;
    }

    svg{
        width: auto;
        height: 100%;
    }

    &:hover,
    &:focus{
        color: var(--primary);
    }
}





/** edit button **/
.cms-edit-container{
    position: fixed;
    z-index: 20;
    left: 0;
    bottom: 0;

    width: 100%;
    max-width: 300px;
}
.cms-edit-link{
    display: inline-block;
    color: black;
    font-weight: 500;
    padding: 20px;
    background: rgba(255,255,0, 1);
    box-shadow: 1px 0px 15px rgba(0,0,0,.15);

    transition: background .5s;

    &:hover,
    &:focus{
        background: rgba(240,230,0, 1);
    }
}

/** sitewide theme preview banner — logged-in users only, see
    _partials/themePreview.twig **/
.theme-preview-banner{
    position: fixed;
    z-index: 30;
    top: var(--header-height);
    left: 0;

    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;

    width: 100%;
    padding: 10px 20px;

    background: #ed2250;
    color: white;
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    box-shadow: 0px 1px 15px rgba(0,0,0,.15);
}

.theme-preview-banner__actions{
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}

.theme-preview-banner__btn{
    display: inline-block;
    padding: 4px 12px;
    border: 1px solid white;
    border-radius: 4px;
    background: transparent;
    color: white;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;

    transition: background .3s;

    &:hover,
    &:focus{
        background: rgba(255,255,255,.15);
    }
}

.theme-preview-banner__btn--primary{
    background: white;
    color: rgba(217,119,6,1);

    &:hover,
    &:focus{
        background: rgba(255,255,255,.85);
    }
}