	--bg-color: var(--bg-customcolor-source, var(--customcolor, var(--primary)));
	--bg-light: var(--customcolor-light, var(--primary-light));
	--bg-dark: var(--customcolor-dark, var(--primary-dark));
	--bg-medium: var(--customcolor-medium, var(--primary-medium));
	--bg-accent: var(--customcolor-accent, var(--primary-accent));
	--bg-complement: var(--customcolor-complement, var(--primary-complement));
	--bg-image: none;
	background-color: var(--bg-color);

	--font-color: var(--bg-customcolor-source-on, var(--on-customcolor, var(--on-primary)));
	--font-color-heading: var(--bg-customcolor-source-on, var(--on-customcolor, var(--on-primary)));
	--link-color: var(--bg-customcolor-source-on, var(--on-customcolor, var(--on-primary)));
	--link-border-color: var(--bg-customcolor-source-on, var(--on-customcolor, var(--on-primary)));
