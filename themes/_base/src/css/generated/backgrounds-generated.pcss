	--bg-medium: var(--neutral-medium, var(--primary-medium));
	--bg-accent: var(--neutral-accent, var(--primary-accent));
	--bg-complement: var(--neutral-complement, var(--primary-complement));
	--bg-image: none;
	background-color: var(--bg-color);

	--font-color: var(--bg-neutral-source-on, var(--on-neutral, var(--on-primary)));
	--font-color-heading: var(--bg-neutral-source-on, var(--on-neutral, var(--on-primary)));
	--link-color: var(--bg-neutral-source-on, var(--on-neutral, var(--on-primary)));
	--link-border-color: var(--bg-neutral-source-on, var(--on-neutral, var(--on-primary)));
	--link-hover-color: var(--bg-neutral-source-on, var(--on-neutral, var(--on-primary)));
	--link-hover-border-color: var(--bg-neutral-source-on, var(--on-neutral, var(--on-primary)));
	--form-label-color: var(--bg-neutral-source-on, var(--on-neutral, var(--on-primary)));
