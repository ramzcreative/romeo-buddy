.lists{
	overflow:hidden;
}
.lists__int{
	display: flex;
	flex-direction: column;
	gap: var(--spacer-6);

	@media (--screen-lg){
		gap: var(--spacer-8);
	}
}
.lists__item{
	display: flex;
	flex-direction: column;
	width: auto;
	margin: 0 calc(var(--spacing-x) * -1);

	gap: var(--spacer-6);

	@media (--screen-md){
		flex-direction: row;
		width: 100%;
		margin: 0;

		padding-top: var(--spacer-6);
		border-top: 1px solid var(--secondary);
	}

	@media (--screen-lg){
		padding-top: var(--spacer-8);
		gap: var(--spacer-7);
	}
}
.lists__image-container{
	flex-shrink: 0;
	width: 100%;

	@media (--screen-md){
		max-width: clamp(300px, 36vw, 500px);
	}
}
.lists__image-wrapper{
	@media (--screen-md){
	 border-radius: var(--radius);
	}	
}
.lists__image{
	width: 100%;
}
.lists__info{
	padding: 0 var(--spacer-5);

	@media (--screen-md){
		padding: 0;
	}
}