/* $colors (color1/color2/color3/black/gray/body/body-medium/line) removed
   2026-07-22 -- migrated to the Color System roles (primary/secondary/
   tertiary/gray) and, for body/body-medium, to plain --body/--body-medium
   lines in the generated block below (see themedesigner/CLAUDE.md and
   project_stables_color1_color2_to_design_system_migration.md -- same
   migration, this site). 'line' was unused (zero CSS consumers found)
   and was simply dropped, not migrated. */
/* Computed design-system colors (Phase 1 of the theme generator) --
   primary/secondary/tertiary/neutral, each with 6 stops (base/light/dark/
   medium/accent/complement) plus a WCAG-computed --on-{role}-{stop} pairing
   (3:1 large-text AA -- these pair with bold button/heading text -- white
   preferred, falling back to dark ink only when white fails that bar).
   Generated by the Theme Designer's Colors tab (modules/themedesigner/
   controllers/DesignerController.php) -- these tokens drive bg-{role}
   (backgrounds-generated.pcss) and .btn-{role} (buttons-generated.pcss)
   across the site, so hand-editing below this line will just get
   overwritten if you click that role's own Regenerate button --
   Save alone never touches a stop you didn't just edit. A stop
   marked "locked" (see the lock icon in the UI) is skipped by
   Regenerate too, so it only ever changes when directly edited. */
:root {
    --primary: #0e8f8a;
    --primary-light: #76d3cd;
    --primary-dark: #004d4a;
    --primary-medium: #598683;
    --primary-accent: #00918c;
    --primary-complement: #8f0e13;
    --on-primary: #ffffff;
    --on-primary-light: #000000;
    --on-primary-dark: #ffffff;
    --on-primary-medium: #ffffff;
    --on-primary-accent: #ffffff;
    --on-primary-complement: #ffffff;

    --secondary: #143c4d;
    --secondary-light: #56798a;
    --secondary-dark: #000713;
    --secondary-medium: #293a42;
    --secondary-accent: #093d50;
    --secondary-complement: #4d2514;
    --on-secondary: #ffffff;
    --on-secondary-light: #ffffff;
    --on-secondary-dark: #ffffff;
    --on-secondary-medium: #ffffff;
    --on-secondary-accent: #ffffff;
    --on-secondary-complement: #ffffff;

    --neutral: #4e4e4f;
    --neutral-light: #8d8d8e;
    --neutral-dark: #171718;
    --neutral-medium: #4e4e4f;
    --neutral-accent: #4e4e4f;
    --neutral-complement: #4f4f4e;
    --on-neutral: #ffffff;
    --on-neutral-light: #ffffff;
    --on-neutral-dark: #ffffff;
    --on-neutral-medium: #ffffff;
    --on-neutral-accent: #ffffff;
    --on-neutral-complement: #ffffff;

    --dark: #000000;
    --dark-light: #1b1b1b;
    --dark-dark: #000000;
    --dark-medium: #000000;
    --dark-accent: #000000;
    --dark-complement: #000000;
    --on-dark: #ffffff;
    --on-dark-light: #ffffff;
    --on-dark-dark: #ffffff;
    --on-dark-medium: #ffffff;
    --on-dark-accent: #ffffff;
    --on-dark-complement: #ffffff;

    --gray: #4e4e4f;
    --gray-light: #8d8d8e;
    --gray-dark: #171718;
    --gray-medium: #4e4e4f;
    --gray-accent: #4e4e4f;
    --gray-complement: #4f4f4e;
    --on-gray: #ffffff;
    --on-gray-light: #ffffff;
    --on-gray-dark: #ffffff;
    --on-gray-medium: #ffffff;
    --on-gray-accent: #ffffff;
    --on-gray-complement: #ffffff;
    --body: #f4f8f7;
    --body-medium: #e3eef0;
}
