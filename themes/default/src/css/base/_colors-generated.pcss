/* $colors (color1/color2/color3/black/gray/body/body-medium/line) removed
   2026-07-22 -- migrated to the Color System roles (primary/secondary/
   tertiary/gray) and, for body/body-medium, to plain --body/--body-medium
   lines in the generated block below (see themedesigner/CLAUDE.md and
   project_stables_color1_color2_to_design_system_migration.md -- same
   migration, this site). 'line' was unused (zero CSS consumers found)
   and was simply dropped, not migrated. */
/* Computed design-system colors (Phase 1 of the theme generator) --
   primary/secondary/tertiary/neutral, each with 6 stops (base/light/dark/
   medium/accent/complement) plus a WCAG-computed --on-{role}-{stop} pairing
   (3:1 large-text AA -- these pair with bold button/heading text -- white
   preferred, falling back to dark ink only when white fails that bar).
   Generated by the Theme Designer's Colors tab (modules/themedesigner/
   controllers/DesignerController.php) -- these tokens drive bg-{role}
   (backgrounds-generated.pcss) and .btn-{role} (buttons-generated.pcss)
   across the site, so hand-editing below this line will just get
   overwritten if you click that role's own Regenerate button --
   Save alone never touches a stop you didn't just edit. A stop
   marked "locked" (see the lock icon in the UI) is skipped by
   Regenerate too, so it only ever changes when directly edited. An
   on-color pairing marked "on-override" (click a tile in the UI to
   set one) keeps its exact hex forever, ignoring the WCAG formula
   entirely, until reset from the UI -- no AA guarantee applies to it. */
:root {
    --primary: #00aeef;
    --primary-light: #84f6ff;
    --primary-dark: #0069a1;
    --primary-medium: #71a9c9;
    --primary-accent: #00affa;
    --primary-complement: #ef4100;
    --on-primary: #000000; /* on-override */
    --on-primary-light: #000000;
    --on-primary-dark: #ffffff;
    --on-primary-medium: #000000;
    --on-primary-accent: #000000;
    --on-primary-complement: #ffffff;

    --secondary: #ff6b4a;
    --secondary-light: #ffba9a;
    --secondary-dark: #ab2803;
    --secondary-medium: #d48b79;
    --secondary-accent: #ff5e36;
    --secondary-complement: #4adeff;
    --on-secondary: #000000;
    --on-secondary-light: #000000;
    --on-secondary-dark: #ffffff;
    --on-secondary-medium: #000000;
    --on-secondary-accent: #ffffff;
    --on-secondary-complement: #000000;

    --tertiary: #f7ddb2;
    --tertiary-light: #fffcd5; /* locked */
    --tertiary-dark: #ae9772; /* locked */
    --tertiary-medium: #ecdfca; /* locked */
    --tertiary-accent: #fadcaa; /* locked */
    --tertiary-complement: #b2ccf7; /* locked */
    --on-tertiary: #000000;
    --on-tertiary-light: #000000;
    --on-tertiary-dark: #000000;
    --on-tertiary-medium: #000000;
    --on-tertiary-accent: #000000;
    --on-tertiary-complement: #000000;

    --neutral: #4a5578;
    --neutral-light: #8a96b8;
    --neutral-dark: #141c38;
    --neutral-medium: #505668;
    --neutral-accent: #48557d;
    --neutral-complement: #786d4a;
    --on-neutral: #ffffff;
    --on-neutral-light: #000000;
    --on-neutral-dark: #ffffff;
    --on-neutral-medium: #ffffff;
    --on-neutral-accent: #ffffff;
    --on-neutral-complement: #ffffff;

    --dark: #14213d;
    --dark-light: #4d5b78;
    --dark-dark: #000005;
    --dark-medium: #1b2230;
    --dark-accent: #122041;
    --dark-complement: #3d3014;
    --on-dark: #ffffff;
    --on-dark-light: #ffffff;
    --on-dark-dark: #ffffff;
    --on-dark-medium: #ffffff;
    --on-dark-accent: #ffffff;
    --on-dark-complement: #ffffff;

    --gray: #4a5578;
    --gray-light: #b5beff;
    --gray-dark: #2c3246;
    --gray-medium: #505668;
    --gray-accent: #48557d;
    --gray-complement: #786d4a;
    --on-gray: #ffffff;
    --on-gray-light: #000000;
    --on-gray-dark: #ffffff;
    --on-gray-medium: #ffffff;
    --on-gray-accent: #ffffff;
    --on-gray-complement: #ffffff;

    --ui-pre-heading: var(--primary);
    --on-ui-pre-heading: var(--on-primary);
    --ui-pre-heading: var(--primary);
    --on-ui-pre-heading: var(--on-primary);
    --alert-success: #00ae2a;
    --alert-warning: #f59e0b;
    --alert-error: #f56565;
    --alert-info: #3b82f6;
    --body: #fffaf0;
    --body-medium: #f3e7e1;
    --ui-pre-heading: var(--primary);
    --on-ui-pre-heading: var(--on-primary);
}
