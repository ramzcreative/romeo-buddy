<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
    body {
        font-family: Helvetica, Arial, sans-serif;
        text-align: center;
        color: #222;
    }
    h1 {
        font-size: 24px;
        margin-bottom: 4px;
    }
    p.intro {
        font-size: 13px;
        color: #444;
        margin-top: 0;
        margin-bottom: 20px;
    }
    table.maze-grid {
        border-collapse: collapse;
        margin: 0 auto;
    }
    .labels {
        font-size: 13px;
        margin-top: 14px;
        color: #555;
    }
</style>
</head>
<body>
    <h1>{{ title }}</h1>
    {% if intro %}<p class="intro">{{ intro }}</p>{% endif %}

    {{ mazeTable|raw }}

    <p class="labels">Start top-left, find your way to the bottom-right!</p>
</body>
</html>
