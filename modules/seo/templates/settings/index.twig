{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "SEO"|t('app') %}
{% set fullPageForm = true %}

{% set formActions = [
    {
        label: 'Save and continue editing'|t('app'),
        redirect: 'seo-settings'|hash,
        shortcut: true,
        retainScroll: true,
    },
] %}

{% block content %}
    {{ actionInput('seo/settings/save') }}
    {{ redirectInput('seo-settings') }}

    <h2>{{ 'Organization'|t('app') }}</h2>

    {{ forms.textField({
        first: true,
        label: 'Organization Name'|t('app'),
        id: 'orgName',
        name: 'orgName',
        value: settings.orgName,
        errors: settings.getErrors('orgName'),
    }) }}

    {{ forms.elementSelectField({
        label: 'Logo'|t('app'),
        id: 'logoId',
        name: 'logoId',
        elementType: 'craft\\elements\\Asset',
        criteria: { kind: 'image' },
        single: true,
        elements: settings.getLogo() ? [settings.getLogo()] : [],
        selectionLabel: 'Choose image'|t('app'),
    }) }}

    <hr>

    <h2>{{ 'Meta Defaults'|t('app') }}</h2>

    {{ forms.textField({
        label: 'Title Separator'|t('app'),
        id: 'titleSeparator',
        name: 'titleSeparator',
        value: settings.titleSeparator,
        placeholder: '|',
    }) }}

    {{ forms.textField({
        label: 'Default Title Template'|t('app'),
        instructions: 'Supports {title}, {separator}, and {siteName}.'|t('app'),
        id: 'defaultTitleTemplate',
        name: 'defaultTitleTemplate',
        value: settings.defaultTitleTemplate,
        placeholder: '{title} {separator} {siteName}',
    }) }}

    {{ forms.textareaField({
        label: 'Default Description'|t('app'),
        id: 'defaultDescription',
        name: 'defaultDescription',
        value: settings.defaultDescription,
    }) }}

    {{ forms.elementSelectField({
        label: 'Default Social/OG Image'|t('app'),
        instructions: 'Used for Open Graph and Twitter Card previews when no more specific image is set.'|t('app'),
        id: 'defaultOgImageId',
        name: 'defaultOgImageId',
        elementType: 'craft\\elements\\Asset',
        criteria: { kind: 'image' },
        single: true,
        elements: settings.getDefaultOgImage() ? [settings.getDefaultOgImage()] : [],
        selectionLabel: 'Choose image'|t('app'),
    }) }}

    <hr>

    <h2>{{ 'Social'|t('app') }}</h2>

    {{ forms.textField({
        label: 'X (Twitter) Handle'|t('app'),
        id: 'twitterHandle',
        name: 'twitterHandle',
        value: settings.twitterHandle,
        placeholder: '@handle',
    }) }}

    {{ forms.textField({
        label: 'X (Twitter) URL'|t('app'),
        id: 'twitterUrl',
        name: 'twitterUrl',
        value: settings.twitterUrl,
    }) }}

    {{ forms.textField({
        label: 'Facebook URL'|t('app'),
        id: 'facebookUrl',
        name: 'facebookUrl',
        value: settings.facebookUrl,
    }) }}

    {{ forms.textField({
        label: 'Instagram URL'|t('app'),
        id: 'instagramUrl',
        name: 'instagramUrl',
        value: settings.instagramUrl,
    }) }}

    {{ forms.textField({
        label: 'LinkedIn URL'|t('app'),
        id: 'linkedinUrl',
        name: 'linkedinUrl',
        value: settings.linkedinUrl,
    }) }}

    {{ forms.textField({
        label: 'YouTube URL'|t('app'),
        id: 'youtubeUrl',
        name: 'youtubeUrl',
        value: settings.youtubeUrl,
    }) }}

    {{ forms.textField({
        label: 'TikTok URL'|t('app'),
        id: 'tiktokUrl',
        name: 'tiktokUrl',
        value: settings.tiktokUrl,
    }) }}

    {{ forms.textField({
        label: 'Pinterest URL'|t('app'),
        id: 'pinterestUrl',
        name: 'pinterestUrl',
        value: settings.pinterestUrl,
    }) }}

    {{ forms.textField({
        label: 'Threads URL'|t('app'),
        id: 'threadsUrl',
        name: 'threadsUrl',
        value: settings.threadsUrl,
    }) }}

    <hr>

    <h2>{{ 'Search Engine Verification'|t('app') }}</h2>

    {{ forms.textField({
        label: 'Google Search Console Verification'|t('app'),
        instructions: 'The content value from the google-site-verification meta tag Search Console gives you — not the whole tag, just the token.'|t('app'),
        id: 'googleSiteVerification',
        name: 'googleSiteVerification',
        value: settings.googleSiteVerification,
    }) }}

    {{ forms.textField({
        label: 'Bing Webmaster Tools Verification'|t('app'),
        instructions: 'The content value from the msvalidate.01 meta tag Bing gives you.'|t('app'),
        id: 'bingSiteVerification',
        name: 'bingSiteVerification',
        value: settings.bingSiteVerification,
    }) }}
{% endblock %}
