{% extends "_layouts/cp" %}

{% set title = "Themes" %}

{% block content %}
    <form method="post" accept-charset="UTF-8" class="theme-picker-form">
        {{ csrfInput() }}
        {{ actionInput('theme-picker/themes/select') }}
        {{ redirectInput('theme-picker') }}

        <div class="theme-picker-grid">
            {% for theme in themes %}
                <label class="theme-picker-card {{ theme.handle == activeHandle ? 'theme-picker-card--active' }}">
                    <input type="radio" name="handle" value="{{ theme.handle }}" {{ theme.handle == activeHandle ? 'checked' }}>
                    <span class="theme-picker-card__thumb">
                        {% if theme.thumbnailUrl %}
                            <img src="{{ theme.thumbnailUrl }}" alt="{{ theme.name }} preview">
                        {% else %}
                            <span class="theme-picker-card__placeholder">No preview</span>
                        {% endif %}
                    </span>
                    <span class="theme-picker-card__name">
                        {{ theme.name }}
                        {% if theme.handle == activeHandle %}
                            <span class="theme-picker-card__badge">Active</span>
                        {% endif %}
                    </span>
                </label>
            {% endfor %}
        </div>

        <button type="submit" class="btn submit">Activate Theme</button>
    </form>
{% endblock %}
