{% set background = entry['background']['color'][0]['background']|default('bg--none') %}
{% set backgroundContent = entry['backgroundContent']['color'][0]['background']|default('bg--none') %}
{% set isLast = last ?? false %}
{% set layout = entry['layoutText'] ?? 'center' %}
{% set parent = parent ?? 'default' %}
{% set blocks = entry['pageBuilder'] ?? null %}

{% set defaultAttr = {
	class: [
		'content-block',
		'overflow-hidden',
		background != 'bg--none' ? background ~ ' section-padding' : background,
		isLast ? 'section--last',
	]
} %}

<article {{attr(defaultAttr)}}>
	{% include '_blocks/partials/heading' %}

	
	{# {{entry.contentBlock}} #}
	{% include "_blocks/_builder" with {"parent": 'builder' } %}
</article>
