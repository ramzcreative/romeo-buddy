{% set background = entry['background']['color'][0]['background']|default('bg--none') %}

{% set defaultAttr = {
    class: [
        'image-text-default relative',
        background,
        'bg--none' in background ? 'section' : 'section-padding',
    ]
} %}

<article {{attr(defaultAttr)}}>

	<div class="wave wave--top">
      <svg viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,60 C240,10 480,90 720,50 C960,10 1200,90 1440,40 L1440,0 L0,0 Z" fill="var(--color-tan)"/>
      </svg>
    </div>

	{% include '_blocks/partials/heading' %}

	<div class="image-text-default__int wrapper">
		<div class="image-text-default__items" data-animations='{
			"transition": "inview",
			"childTarget": "[data-children]"
    	}'>

			{% for item in items %}
				{% include "_blocks/partials/imageText/defaultPartial" with { item: item, index: loop.index0, reverse: reverse } only %}
			{% endfor %}

		</div>
	</div>

	<div class="wave wave--bottom">
      <svg viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,60 C240,10 480,90 720,50 C960,10 1200,90 1440,40 L1440,0 L0,0 Z" fill="var(--color-tan)"/>
      </svg>
    </div>
</article>