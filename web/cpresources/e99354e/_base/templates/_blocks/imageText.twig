{% set isLast = last ?? false %}
{% set layout = entry['layoutImageText'] ?? 'default' %}    
{% set items = entry.imageItems.all() ?? false %}
{% set reverse = entry['reverse']|default(false) ? true : false %}

{% if items %}
	{% include "_blocks/layouts/imageText/#{layout}" with{items: items, reverse: reverse, uid: entry.uid } %}
{% endif %}