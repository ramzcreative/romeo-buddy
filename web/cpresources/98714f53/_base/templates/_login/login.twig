{% set globalShowForm = true %}

{% embed '_base' %}
{% block content %}
<article class="section portal-login-block">
    <div class="wrapper">
        <form-js>
            <form class="form-login" method="post" accept-charset="UTF-8">
                {{ csrfInput() }}
                {{ actionInput('users/login') }}

                <div class="fui-page-container">

                    <div>
                        {% if errorMessage is defined %}
                        <p class="alert-error">{{ errorMessage }}</p>
                        {% endif %}
                    </div>

                    <div class="fui-row fui-page-row">
                        <div class="fui-field">
                            <div class="fui-field-container">
                                <label class="fui-label" for="loginName">Username or email</label>
                                <div class="fui-input-container">
                                    {{ input('text', 'loginName', craft.app.user.rememberedUsername, {
                                        id: 'loginName',
                                        class: 'fui-input',
                                    }) }}
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="fui-row fui-page-row">
                        <div class="fui-field">
                            <div class="fui-field-container">
                                <label class="fui-label" for="password">Password</label>
                                {{ input('password', 'password', null, {
                                    id: 'password',
                                    class:'fui-input'
                                }) }}
                            </div>
                        </div>
                    </div>

                    <div class="fui-row fui-page-row">
                        <div class="fui-field fui-type-checkboxes">
                            <fieldset class="fui-fieldset fui-layout-vertical">
                                <div class="fui-input-container">
                                    <div class="fui-layout-wrap">
                                        <div class="fui-checkbox">
                                            {{ input('checkbox', 'rememberMe', '1', {
                                                class: 'fui-input fui-checkbox-input',
                                                id: 'login-remember'
                                            }) }}
                                            <label class="fui-checkbox-label" for="login-remember">Remember me</label>
                                        </div>
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>
                    

                    <div>
                        <button class="btn">Login</button>
                    </div>

                </div>
            </form>
        </form-js>
        
        <p><a href="{{ url('portal/reset-password') }}">Forgot your password?</a></p>
    </div>
</article>
{% endblock %}
{% endembed %}